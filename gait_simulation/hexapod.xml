<!-- Custom instatiation of hexapod - pawojcik -->
<!-- Used Blender to organize the components into the hexapod shape, referred to the Blender coordinates for individual component positioning -->

<mujoco model="hexapod">
    <option timestep="0.002" gravity="0 0 -9.81"/>
    <compiler inertiafromgeom="true" angle="degree" autolimits="true"/>

    <!-- for fun -->
    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" 
                 rgb2=".2 .3 .4" width="300" height="300" mark="edge" 
                 markrgb="0.8 0.8 0.8"/>
        
        <material name="grid" texture="grid" texrepeat="5 5" 
                  texuniform="true"/>

        <!-- OBJ components -->
        <mesh name="hexapod_body" file="blender_obj/hexapod_wc.obj" scale="1 1 1"/>
        <mesh name="hip1" file="blender_obj/hip1_wc.obj" scale="1 1 1"/>
        <mesh name="knee1" file="blender_obj/knee1_wc.obj" scale="1 1 1"/>
        <mesh name="leg1" file="blender_obj/leg1_wc.obj" scale="1 1 1"/>

        <mesh name="hip2" file="blender_obj/hip2_wc.obj" scale="1 1 1"/>
        <mesh name="knee2" file="blender_obj/knee2_wc.obj" scale="1 1 1"/>
        <mesh name="leg2" file="blender_obj/leg2_wc.obj" scale="1 1 1"/>

        <mesh name="hip3" file="blender_obj/hip3_wc.obj" scale="1 1 1"/>
        <mesh name="knee3" file="blender_obj/knee3_wc.obj" scale="1 1 1"/>
        <mesh name="leg3" file="blender_obj/leg3_wc.obj" scale="1 1 1"/>

        <mesh name="hip4" file="blender_obj/hip4_wc.obj" scale="1 1 1"/>
        <mesh name="knee4" file="blender_obj/knee4_wc.obj" scale="1 1 1"/>
        <mesh name="leg4" file="blender_obj/leg4_wc.obj" scale="1 1 1"/>

        <mesh name="hip5" file="blender_obj/hip5_wc.obj" scale="1 1 1"/>
        <mesh name="knee5" file="blender_obj/knee5_wc.obj" scale="1 1 1"/>
        <mesh name="leg5" file="blender_obj/leg5_wc.obj" scale="1 1 1"/>

        <mesh name="hip6" file="blender_obj/hip6_wc.obj" scale="1 1 1"/>
        <mesh name="knee6" file="blender_obj/knee6_wc.obj" scale="1 1 1"/>
        <mesh name="leg6" file="blender_obj/leg6_wc.obj" scale="1 1 1"/>
    </asset>

    <worldbody>
        <light pos="0 0 2" dir="0 0 -1"/>
        <geom name="floor" type="plane" size="5 5 0.1" material="grid" rgba="0.8 0.8 0.8 1"/>

        <body name="torso" pos="0 0 0">
            <geom type="mesh" mesh="hexapod_body"/>
            <!-- <freejoint/> -->

            <!-- TRY THIS - body is supported by a central beam, control its movement as such -->
            <joint name="torso_x" type="slide" axis="1 0 0"/>
            <joint name="torso_y" type="slide" axis="0 1 0"/>
            <joint name="torso_yaw" type="hinge" axis="0 0 1"/>

            <!-- RIGHT SIDE -->
            
            <body name="leg1">
                <body name="hip1">
                    <joint name="hip1_joint" pos="0.18 -0.18 0.6" axis="0 0 1" type="hinge" range="0 60" ref="30"/>
                    <geom type="mesh" mesh="hip1" rgba="1 0 0 1"/>

                    <body name="knee1">
                        <geom type="mesh" mesh="knee1" rgba="1 0 0 1"/>

                        <body name="legpart1" pos="0 0 0">
                            <joint name="knee1_joint"
                                type="hinge"
                                axis="0 -1 0"
                                range="90 120"
                                ref="120" pos="0.32 -0.18 0.6" />
                            <geom type="mesh" mesh="leg1" rgba="1 0 0 1"/>
                        </body>
                    </body>
                </body>
            </body>


            <!-- Green leg 2 -->
            <body name="leg2">
                <body name="hip2">
                    <joint name="hip2_joint" pos="0.22 0 0.6" axis="0 0 1" type="hinge" range="0 60" ref="30" />
                    <geom type="mesh" mesh="hip2" rgba="0 1 0 1"/>

                    <body name="knee2">
                        
                        <geom type="mesh" mesh="knee2" rgba="0 1 0 1"/>
                        <body name="legpart2">
                            <joint name="knee2_joint" pos="0.37 0 0.6" axis="0 -1 0" type="hinge" range="90 120" ref="120"/>
                            <geom type="mesh" mesh="leg2" rgba="0 1 0 1"/>
                        </body>
                    </body>
                </body>
            </body>

            <!-- Blue leg 3 -->
            <body name="leg3">
                <body name="hip3">
                    <joint name="hip3_joint" pos="0.18 0.18 0.6" axis="0 0 1" type="hinge" range="0 60" ref="30"/>
                    <geom type="mesh" mesh="hip3" rgba="0 0 1 1"/>

                    <body name="knee3">
                    
                        <geom type="mesh" mesh="knee3" rgba="0 0 1 1"/>

                        <body name="legpart3">
                            <joint name="knee3_joint" pos="0.32 0.18 0.6" axis="0 -1 0" type="hinge" range="90 120" ref="120"/>
                            <geom type="mesh" mesh="leg3" rgba="0 0 1 1"/>
                        </body>
                    </body>
                </body>
            </body>

            <!-- LEFT SIDE -->

            <!-- Yellow leg 4 -->
            <body name="leg4">
                <body name="hip4">
                    <joint name="hip4_joint" pos="-0.18 -0.18 0.6" axis="0 0 1" type="hinge" range="0 60" ref="30" />
                    <geom type="mesh" mesh="hip4" rgba="1 1 0 1"/>


                    <body name="knee4">
                    
                        <geom type="mesh" mesh="knee4" rgba="1 1 0 1"/>

                        <body name="legpart4">
                            <joint name="knee4_joint" pos="-0.32 -0.18 0.6" axis="0 -1 0" type="hinge" range="90 120" ref="90"/>
                            <geom type="mesh" mesh="leg4" rgba="1 1 0 1"/>
                        </body>
                    </body>
                </body>


            </body>

            <!-- Cyan leg 5 -->
            <body name="leg5">
                <body name="hip5">
                    <joint name="hip5_joint" pos="-0.2 0 0.6" axis="0 0 1" type="hinge" range="0 60"/>
                    <geom type="mesh" mesh="hip5" rgba="0 1 1 1"/>

                    <body name="knee5">
                    
                        <geom type="mesh" mesh="knee5" rgba="0 1 1 1"/>

                        <body name="legpart5">
                            <joint name="knee5_joint" pos="-0.36 0 0.6" axis="0 -1 0" type="hinge" range="90 120" ref="90"/>
                            <geom type="mesh" mesh="leg5" rgba="0 1 1 1"/>
                        </body>
                    </body>
                </body>


            </body>

            <!-- Magenta leg 6 -->
            <body name="leg6">
                <body name="hip6">
                    <joint name="hip6_joint" pos="-0.18 0.18 0.6" axis="0 0 1" type="hinge" range="0 60" ref="30" />
                    <geom type="mesh" mesh="hip6" rgba="1 0 1 1"/>

                    <body name="knee6">
                    
                        <geom type="mesh" mesh="knee6" rgba="1 0 1 1"/>

                        <body name="legpart6">
                            <joint name="knee6_joint" pos="-0.32 0.18 0.6" axis="0 -1 0" type="hinge" range="90 120" ref="90"/>
                            <geom type="mesh" mesh="leg6" rgba="1 0 1 1"/>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <!-- HIP MOVEMENT ACTUATION -->
        <position name="hip1_act" joint="hip1_joint" kp="4000" kv="60"/>
        <position name="hip2_act" joint="hip2_joint" kp="4000" kv="60"/>
        <position name="hip3_act" joint="hip3_joint" kp="4000" kv="60"/>
        <position name="hip4_act" joint="hip4_joint" kp="4000" kv="60"/>
        <position name="hip5_act" joint="hip5_joint" kp="4000" kv="60"/>
        <position name="hip6_act" joint="hip6_joint" kp="4000" kv="60"/> 

        <!-- KNEE MOVEMENT ACTUATION -->
        <!-- kp and kv control how "powerful" the actuator is -->
        <!-- CTRL range is in radians, and is between 90 deg and 120 deg -->
        <!-- <position name="knee1_act" joint="knee1_joint" kp="40" kv="6" ctrlrange="0.0 0.5236"/> -->
        <!-- <motor name="knee1_act" joint="knee1_joint" gear="50" ctrlrange="-4.5 4.5" user="2900"/> -->
        <position name="knee1_act" joint="knee1_joint" kp="400" kv="60"/>
        <position name="knee2_act" joint="knee2_joint" kp="400" kv="60"/>
        <position name="knee3_act" joint="knee3_joint" kp="400" kv="60"/>
        <position name="knee4_act" joint="knee4_joint" kp="400" kv="60"/>
        <position name="knee5_act" joint="knee5_joint" kp="400" kv="60"/>
        <position name="knee6_act" joint="knee6_joint" kp="400" kv="60"/>

    </actuator>

    <!-- Not sure if needed but have it anyway -->
    <contact>
        <exclude body1="torso" body2="leg1"/>
        <exclude body1="torso" body2="leg2"/>
        <exclude body1="torso" body2="leg3"/>
        <exclude body1="torso" body2="leg4"/>
        <exclude body1="torso" body2="leg5"/>
        <exclude body1="torso" body2="leg6"/>

        <exclude body1="leg1" body2="leg2"/>
        <!-- <exclude body1="leg2" body2="leg3"/>
        <exclude body1="leg2" body2="leg3"/>
        <exclude body1="leg4" body2="leg5"/>
        <exclude body1="leg5" body2="leg6"/> -->

    </contact>
</mujoco>