<mujoco model="hexapod">
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <!-- Custom instatiation of hexapod - corner legs angle outward -->

    <worldbody>
        <light pos="0 0 2" dir="0 0 -1"/>
        <geom name="floor" type="plane" size="5 5 0.1" rgba="0.8 0.8 0.8 1"/>

        <body name="torso" pos="0 0 0.15">
            <freejoint/>  <!-- lets torso move -->
            <geom type="box" size="0.2 0.1 0.04" rgba="0.4 0.4 0.8 1"/>

            <!-- Leg1 front left (corner) — angled 45° outward -->
            <body name="leg1" pos="0.2 0.1 0" euler="0 0 45">
                <joint name="hip1" type="hinge" axis="0 0 1" range="-60 60"/>
                <geom type="capsule" fromto="0 0 0  0.08 0 0" size="0.015"/>
                <body name="knee_joint_1" pos="0.08 0 0">
                    <joint name="knee1" type="hinge" axis="0 1 0" range="-90 10"/>
                    <geom type="capsule" fromto="0 0 0  0.1 0 -0.05" size="0.012"/>
                </body>
            </body>

            <!-- Leg2 middle left — straight out, no corner angle -->
            <body name="leg2" pos="0 0.1 0" euler="0 0 90">
                <joint name="hip2" type="hinge" axis="0 0 1" range="-60 60"/>
                <geom type="capsule" fromto="0 0 0  0.08 0 0" size="0.015"/>
                <body name="knee_joint_2" pos="0.08 0 0">
                    <joint name="knee2" type="hinge" axis="0 1 0" range="-90 10"/>
                    <geom type="capsule" fromto="0 0 0  0.1 0 -0.05" size="0.012"/>
                </body>
            </body>

            <!-- Leg3 back left (corner) — angled 135° outward -->
            <body name="leg3" pos="-0.20 0.10 0" euler="0 0 135">
                <joint name="hip3" type="hinge" axis="0 0 1" range="-60 60"/>
                <geom type="capsule" fromto="0 0 0  0.08 0 0" size="0.015"/>
                <body name="knee_joint_3" pos="0.08 0 0">
                    <joint name="knee3" type="hinge" axis="0 1 0" range="-90 10"/>
                    <geom type="capsule" fromto="0 0 0  0.1 0 -0.05" size="0.012"/>
                </body>
            </body>

            <!-- Leg4 back right (corner) — angled -135° outward -->
            <body name="leg4" pos="-0.2 -0.1 0" euler="0 0 -135">
                <joint name="hip4" type="hinge" axis="0 0 1" range="-60 60"/>
                <geom type="capsule" fromto="0 0 0  0.08 0 0" size="0.015"/>
                <body name="knee_joint_4" pos="0.08 0 0">
                    <joint name="knee4" type="hinge" axis="0 1 0" range="-90 10"/>
                    <geom type="capsule" fromto="0 0 0  0.1 0 -0.05" size="0.012"/>
                </body>
            </body>

            <!-- Leg5 middle right — straight out, no corner angle -->
            <body name="leg5" pos="0 -0.1 0" euler="0 0 -90">
                <joint name="hip5" type="hinge" axis="0 0 1" range="-60 60"/>
                <geom type="capsule" fromto="0 0 0  0.08 0 0" size="0.015"/>
                <body name="knee_joint_5" pos="0.08 0 0">
                    <joint name="knee5" type="hinge" axis="0 1 0" range="-90 10"/>
                    <geom type="capsule" fromto="0 0 0  0.1 0 -0.05" size="0.012"/>
                </body>
            </body>

            <!-- Leg6 front right (corner) — angled -45° outward -->
            <body name="leg6" pos="0.20 -0.10 0" euler="0 0 -45">
                <joint name="hip6" type="hinge" axis="0 0 1" range="-60 60"/>
                <geom type="capsule" fromto="0 0 0  0.08 0 0" size="0.015"/>
                <body name="knee_joint_6" pos="0.08 0 0">
                    <joint name="knee6" type="hinge" axis="0 1 0" range="-90 10"/>
                    <geom type="capsule" fromto="0 0 0  0.1 0 -0.05" size="0.012"/>
                </body>
            </body>

        </body>
    </worldbody>

    <actuator>
        <!-- 2 per leg, 12 total -->
        <position name="act_hip_1"  joint="hip1"  kp="10"/>
        <position name="act_knee_1" joint="knee1" kp="10"/>

        <position name="act_hip_2"  joint="hip2"  kp="10"/>
        <position name="act_knee_2" joint="knee2" kp="10"/>

        <position name="act_hip_3"  joint="hip3"  kp="10"/>
        <position name="act_knee_3" joint="knee3" kp="10"/>

        <position name="act_hip_4"  joint="hip4"  kp="10"/>
        <position name="act_knee_4" joint="knee4" kp="10"/>

        <position name="act_hip_5"  joint="hip5"  kp="10"/>
        <position name="act_knee_5" joint="knee5" kp="10"/>

        <position name="act_hip_6"  joint="hip6"  kp="10"/>
        <position name="act_knee_6" joint="knee6" kp="10"/>
    </actuator>
</mujoco>